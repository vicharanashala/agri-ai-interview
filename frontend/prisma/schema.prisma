generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — set when using email/password auth
  accounts      Account[]
  sessions      Session[]
  candidate     Candidate?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Candidate {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Personal Information
  fullName          String
  phone             String?
  
  // Location
  state             String?
  district          String?
  pincode           String?
  address           String?
  
  // Professional Background
  currentRole       String?
  yearsOfExperience Int?
  highestEducation  String?
  institution       String?
  
  // Agricultural Domain Specific
  farmingBackground String?
  cropsGrown        String?
  farmSize          String?
  primaryExpertise  String?
  
  // Relations for admin dashboard
  interviewSessions InterviewSession[]
  phaseHistory      PhaseHistory[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Admin {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model InterviewSession {
  id              String   @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status          String   @default("active") // active, completed, cancelled
  currentPhase    String   @default("interview")
  interviewData   String?  // JSON string for interview state
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  messages        InterviewMessage[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InterviewMessage {
  id              String   @id @default(cuid())
  interviewSessionId String
  interviewSession InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  role            String   // 'assistant' or 'user'
  content         String
  timestamp       DateTime @default(now())
}

model PhaseHistory {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  phase       String    // onboarding, signing, interview, summary, offer, joining
  status      String    @default("pending") // pending, in_progress, completed
  timestamp   DateTime  @default(now())
  completedAt DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([candidateId, phase])
}

model EvaluationCriteria {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  weight      Int      @default(1) // Weight for scoring (1-10)
  order       Int      @default(0) // Display order
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemGuidelines {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., 'question_guidelines', 'evaluation_system'
  content     String
  updatedAt   DateTime @updatedAt
}
