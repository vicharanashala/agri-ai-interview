generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — set when using email/password auth
  accounts      Account[]
  sessions      Session[]
  candidate     Candidate?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Candidate {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Personal Information
  fullName          String?
  phone             String?
  
  // Location
  state             String?
  district          String?
  pincode           String?
  address           String?
  
  // Professional Background
  currentRole       String?
  yearsOfExperience Int?
  highestEducation  String?
  institution       String?
  
  // Agricultural Domain Specific
  farmingBackground String?
  cropsGrown        String?
  farmSize          String?
  primaryExpertise  String?
  
  // Relations for admin dashboard
  interviewSessions InterviewSession[]
  phaseHistory      PhaseHistory[]
  resumes           Resume[]
  
  // Current pipeline phase (onboarding | interview | summary | offer | signing | joining)
  currentPhase      String   @default("onboarding")
  
  // Flag: candidate viewed offer letter (unlocks signing phase)
  offerLetterViewed    Boolean  @default(false)
  // Flag: candidate visited summary page (unlocks offer phase)
  passedAndVisitedSummary Boolean @default(false)
  // Flag: candidate visited joining details
  joiningDetailsVisited Boolean  @default(false)
  
  // Signed offer letter record (one per candidate)
  signedOfferLetter SignedOfferLetter?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SignedOfferLetter {
  id            String    @id @default(cuid())
  candidateId   String    @unique
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  pdfData       Bytes                  // Full signed PDF as binary
  signatureName String                 // E-signature name used
  signedAt      DateTime @default(now())
  createdAt     DateTime  @default(now())

  @@map("signed_offer_letters")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Admin {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Singleton table — persists active_interview_count across server restarts.
// Single row with id='singleton'.
model ActiveInterviewCount {
  id        String   @id @default("singleton")
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model InterviewQueueEntry {
  id              String    @id @default(cuid())
  candidateId     String    @unique
  status          String    @default("queued") // queued | ready | interviewing | paused | cancelled | skipped | completed
  position        Int?
  scheduledAt     DateTime?
  joinedAt        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  skippedAt       DateTime?
  cooldownUntil   DateTime?
  skipCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model InterviewStateSnapshot {
  id                  String   @id @default(cuid())
  candidateId         String
  queueEntryId        String
  questionCount       Int
  conversationHistory String   // JSON string
  createdAt           DateTime @default(now())
}

model InterviewSession {
  id              String    @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  queueEntryId    String?
  startedViaQueue Boolean   @default(false)
  status          String    @default("active") // active, completed, cancelled
  result          String?   // PASS, FAIL
  endReason       String?   // anti_cheat, withdrawn, question_limit, time_limit
  score           Float?    // 0–100 from LLM evaluation
  currentPhase    String    @default("interview")
  interviewData   String?   // JSON string for interview state
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  
  messages        InterviewMessage[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model InterviewMessage {
  id              String   @id @default(cuid())
  interviewSessionId String
  interviewSession InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  role            String   // 'assistant' or 'user'
  content         String
  timestamp       DateTime @default(now())
}

model PhaseHistory {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  phase       String    // onboarding, signing, interview, summary, offer, joining
  status      String    @default("pending") // pending, in_progress, completed
  timestamp   DateTime  @default(now())
  completedAt DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([candidateId, phase])
}

model EvaluationCriteria {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  weight      Int      @default(1) // Weight for scoring (1-10)
  order       Int      @default(0) // Display order
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemGuidelines {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., 'question_guidelines', 'evaluation_system'
  content     String
  updatedAt   DateTime @updatedAt
}

model AntiCheatEvent {
  id              String   @id @default(cuid())
  candidateId     String
  interviewId     String?
  eventType       String   // 'tab_switch' | 'copy' | 'paste' | 'right_click' | 'window_blur' | 'fullscreen_exit'
  severity        String   @default("warning") // 'warning' | 'critical'
  message         String?
  metadata        String?  // JSON string for extra context
  createdAt       DateTime @default(now())

  @@index([candidateId])
  @@index([interviewId])
  @@index([eventType])
  @@index([createdAt])
}

model Resume {
  id          String   @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String   // "pdf" | "docx"
  rawText     String?  // extracted text content
  parsedData  String?  // JSON string — structured parsed output (Phase 2)
  skills      String?  // JSON list string — normalised skills
  summary     String?  // 2-3 sentence profile summary
  status      String   @default("pending") // "pending" | "uploaded" | "parsed" | "failed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([candidateId])
}

model Settings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String?
  description String?
  category    String   @default("general") // general | interview | evaluation | notification
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
