{
  "hosting": {
    "site": "agri-interview-platform-prod",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "agri-interview-frontend-prod",
          "region": "asia-south1"
        }
      }
    ]
  }
}